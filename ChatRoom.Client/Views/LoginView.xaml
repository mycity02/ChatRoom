<Window x:Class="ChatRoom.Client.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatRoom.Client.Views"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Title="聊天室-登录" Height="450" Width="450">
    <Grid Background="#F5F5F5">
        <Border Width="360" 
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel Margin="30">
                <!--标题-->
                <TextBlock Text="聊天室" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,20,0,25"
                           Foreground="#2196F3"/>
                
                <!--用户名-->
                <TextBlock Text="用户名" FontSize="13" Margin="0,0,0,4"
                           Foreground="#666"/>
                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                         Height="32" FontSize="14" Margin="0,0,0,12"/>
                
                <!-- 密码 -->
                <TextBlock Text="密码" FontSize="13" Margin="0,0,0,4"
                           Foreground="#666"/>
                <PasswordBox x:Name="PasswordBox" Height="32" FontSize="14"
                             Margin="0,0,0,12"/>
                
                <!-- 按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="登录" Command="{Binding LoginCommand}"
                            CommandParameter="{Binding ElementName=PasswordBox}"
                            Width="100" Height="32" Margin="0,0,12,0"
                            Background="#2196F3" Foreground="White"
                            BorderThickness="0" FontSize="13"/>
                    <Button Content="注册" Command="{Binding RegisterCommand}"
                            CommandParameter="{Binding ElementName=PasswordBox}"
                            Width="100" Height="32"
                            Background="#4CAF50" Foreground="White"
                            BorderThickness="0" FontSize="13"/>
                </StackPanel>
                
                <!-- 错误提示 -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F44336"
                           FontSize="12" Margin="0,12,0,0"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
            
    </Grid>
</Window>
