<Window x:Class="ChatRoom.Client.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatRoom.Client.Views"
        mc:Ignorable="d"
        Title="聊天室" Height="650" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#2196F3" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="当前用户：" Foreground="White" FontSize="13" 
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentUserName}" Foreground="White"
                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="创建群聊" Width="80" Height="26" Margin="0,0,8,0"
                            FontSize="12"/>
                    <Button Content="添加好友" Width="80" Height="26" Margin="0,0,8,0"
                            FontSize="12" Command="{Binding FriendPanel.AddFriendRequestCommand}"/>
                    <Button Content="退出" Width="60" Height="26" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 主体 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧会话列表 -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0"
                    BorderThickness="0,0,1,0" Background="#FAFAFA">

                <TabControl BorderThickness="0"
                            Background="Transparent">
                    
                    <!-- 会话Tab -->
                    <TabItem Header="会话">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="12,8"
                                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                <TextBlock Text="我的会话"
                                           FontWeight="Bold"
                                           FontSize="14"/>
                            </Border>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding PrivateSessionCollection}"
                                     SelectedItem="{Binding SelectedSession}"
                                     BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="32" Height="32"
                                                        CornerRadius="16"
                                                        Background="#2196F3"
                                                        Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding Icon}"
                                                               Foreground="White"
                                                               FontSize="14" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding OtherUserName}"
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   Foreground="#333"/>

                                                    <TextBlock Text="{Binding LastMessage}"
                                                   FontSize="12"
                                                   Foreground="#999"
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </StackPanel> 
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                    
                    <!-- 好友Tab -->
                    <TabItem Header="好友">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 收到的好友申请区域 -->
                            <Expander Grid.Row="0" Header="收到的申请"
                                      IsExpanded="True" MaxHeight="100">
                                <ListBox ItemsSource="{Binding FriendPanel.FriendRequestCollection}"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding RequestUserName}"
                                                               FontWeight="Bold" FontSize="13"/>
                                                    <TextBlock Text="{Binding CreateTime, StringFormat=yyyy-MM-dd HH:mm}"
                                                               FontSize="11"
                                                               Foreground="#999"
                                                               Margin="0,4,0,0"/>

                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                        <Button Content="同意" Width="52" Height="24"
                                                                Margin="0,0,8,0" FontSize="12"
                                                                Command="{Binding DataContext.FriendPanel.AcceptFriendRequestCommand,
                                                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"/>
                                                        <Button Content="拒绝" Width="52" Height="24"
                                                                FontSize="12"
                                                                Command="{Binding DataContext.FriendPanel.RejectFriendRequestCommand,
                                                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Expander>

                            <!-- 发出的好友申请区域 -->
                            <Expander Grid.Row="1" Header="发出的申请"
                                      IsExpanded="True" MaxHeight="120">
                                <ListBox ItemsSource="{Binding FriendPanel.SentFriendRequestCollection}"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,8">
                                                <StackPanel>
                                                    <!-- ReceivedUserName 是我申请添加的用户 -->
                                                    <TextBlock Text="{Binding ReceivedUserName}"
                                                               FontWeight="Bold" FontSize="13"/>

                                                    <!-- Status 是这条申请当前状态：pending / accepted / rejected -->
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="12"
                                                               Foreground="#2196F3"
                                                               Margin="0,4,0,0"/>

                                                    <TextBlock Text="{Binding CreateTime, StringFormat=yyyy-MM-dd HH:mm}"
                                                               FontSize="11"
                                                               Foreground="#999"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Expander>

                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="12,8"
                                        BorderBrush="#E0E0E0" BorderThickness="0,1,0,1">
                                    <TextBlock Text="好友列表" FontWeight="Bold" FontSize="14"/>
                                </Border>

                                <ListBox Grid.Row="1" ItemsSource="{Binding FriendPanel.FriendCollection}"
                                         BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="32" Height="32"
                                                            CornerRadius="16" Background="#4CAF50"
                                                            Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding UserName}" 
                                                                   Foreground="White" FontSize="14"
                                                                   FontWeight="Bold" 
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <TextBlock Text="{Binding UserName}"
                                                               FontWeight="Bold"
                                                               FontSize="13"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <Grid Grid.Column="1">
                <!-- 没有选中会话时显示 -->
                <Border Background="White">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSession}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    
                    <TextBlock Text="请选择一个会话" Foreground="#999"
                               FontSize="16" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                
                <!-- 显示选中的会话 -->
                <ContentControl Content="{Binding SelectedSession}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSession}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                    
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 标题 -->
                                <Border Grid.Row="0" Padding="12, 8"
                           BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                           Background="#F5F5F5">
                                    <TextBlock Text="{Binding OtherUserName}"
                                  FontWeight="Bold" FontSize="14"
                                  VerticalAlignment="Center"/>
                                </Border>

                                <!-- 消息列表 -->
                                <ListBox Grid.Row="1"
                            ItemsSource="{Binding MessageCollection}"
                            BorderThickness="0"
                            ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,4">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding UserName}" 
                                          FontWeight="Bold"
                                          FontSize="12"
                                          Foreground="#2196F3"/>
                                                        <TextBlock Text=": "
                                          FontSize="12"
                                          Foreground="#999"/>
                                                        <TextBlock Text="{Binding SendTime, StringFormat=HH:mm}" 
                                          FontSize="11" Foreground="#BBB" 
                                          Margin="8,0,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Content}" FontSize="13" 
                                      Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- 输入区域 -->
                                <Border Grid.Row="2" Padding="12"
                           BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                           Background="#FAFAFA">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                    Text="{Binding NewMessage, UpdateSourceTrigger=PropertyChanged}"
                                    Height="40" FontSize="13"
                                    VerticalContentAlignment="Center"
                                    Padding="8,0"/>
                                        <Button Grid.Column="1"
                                   Content="发送"
                                   Command="{Binding SendCommand}"
                                   Width="70" Height="40"
                                   Margin="8,0,0,0" FontSize="13"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</Window>




